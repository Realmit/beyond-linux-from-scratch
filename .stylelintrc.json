{
  "rules": {
    "selector-type-no-unknown": [true, {
      "ignoreTypes": [
        "window", "treeview", "paned", "progressbar", "infobar",
        "border", "arrow", "trough", "menuitem", "slider",
        "switch", "spinner", "expander", "link", "frame",
        "notebook", "toolbar", "dialog", "menu", "menubar",
        "scrollbar", "entry", "button", "header", "title"
      ]
    }],
    "at-rule-no-unknown": [true, {
      "ignoreAtRules": ["define-color"]
    }]
  }
}