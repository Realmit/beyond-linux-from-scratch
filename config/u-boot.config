# U-Boot Configuration for LFS on ARM/ARM64 boards
# Target: Raspberry Pi 4, Orange Pi, Banana Pi, etc.

# ============================================================================
# GENERAL CONFIGURATION
# ============================================================================
CONFIG_ARM=y
CONFIG_ARM64=y
CONFIG_ARCH_BCM283X=y
CONFIG_TARGET_RPI_4=y
CONFIG_DEFAULT_DEVICE_TREE="bcm2711-rpi-4-b"

# ============================================================================
# BOOT OPTIONS
# ============================================================================
CONFIG_BOOTDELAY=3
CONFIG_BOOTCOMMAND="run distro_bootcmd"
CONFIG_BOOTARGS="console=ttyAMA0,115200 root=/dev/mmcblk0p3 rootwait"

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================
CONFIG_ENV_SIZE=0x4000
CONFIG_ENV_IS_IN_FAT=y
CONFIG_ENV_FAT_INTERFACE="mmc"
CONFIG_ENV_FAT_DEVICE_AND_PART="0:1"

# ============================================================================
# FILESYSTEM SUPPORT
# ============================================================================
CONFIG_CMD_EXT4=y
CONFIG_CMD_FAT=y
CONFIG_CMD_FS_GENERIC=y
CONFIG_DOS_PARTITION=y
CONFIG_EFI_PARTITION=y

# ============================================================================
# NETWORK SUPPORT
# ============================================================================
CONFIG_CMD_NET=y
CONFIG_CMD_DHCP=y
CONFIG_CMD_PING=y
CONFIG_NET_RANDOM_ETHADDR=y
CONFIG_ETH_DESIGNWARE=y

# ============================================================================
# USB SUPPORT
# ============================================================================
CONFIG_CMD_USB=y
CONFIG_USB=y
CONFIG_USB_STORAGE=y
CONFIG_USB_KEYBOARD=y
CONFIG_USB_HOST_ETHER=y

# ============================================================================
# MMC/SD CARD SUPPORT
# ============================================================================
CONFIG_MMC=y
CONFIG_MMC_BCM2835=y
CONFIG_CMD_MMC=y

# ============================================================================
# CONSOLE AND DEBUG
# ============================================================================
CONFIG_SYS_CBSIZE=512
CONFIG_SYS_PBSIZE=1024
CONFIG_SYS_PROMPT="LFS-BOOT # "
CONFIG_SYS_LONGHELP=y
CONFIG_AUTO_COMPLETE=y
CONFIG_CMDLINE_EDITING=y
CONFIG_SYS_HUSH_PARSER=y

# ============================================================================
# EFI LOADER SUPPORT (for UEFI boot)
# ============================================================================
CONFIG_EFI_LOADER=y
CONFIG_EFI_SET_TIME=y
CONFIG_EFI_RUNTIME_UPDATE_CAPSULE=y

# ============================================================================
# SOURCE LOCATIONS
# ============================================================================
# U-Boot source: git://git.denx.de/u-boot.git
# For Raspberry Pi: https://github.com/u-boot/u-boot