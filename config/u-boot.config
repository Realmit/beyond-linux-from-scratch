# ============================================================================
# U-BOOT CONFIGURATION FOR ARM64/ARM32 BOARDS
# For Raspberry Pi, Orange Pi, Rockchip, Allwinner, etc.
# ============================================================================

# ============================================================================
# BOARD SELECTION
# ============================================================================
# Options: rpi4, rpi5, orangepi5, rockpro64, pinebookpro, qemu-arm
BOARD_TYPE="rpi4"

# U-Boot version
UBOOT_VERSION="2024.10"

# ============================================================================
# BUILD CONFIGURATION
# ============================================================================
# Number of parallel jobs
UBOOT_JOBS="$(nproc)"

# Cross-compilation (for ARM builds on x86_64)
UBOOT_CROSS_COMPILE="aarch64-linux-gnu-"

# U-Boot configuration file
case "$BOARD_TYPE" in
    rpi4)
        UBOOT_CONFIG="rpi_4_defconfig"
        UBOOT_ARCH="arm64"
        ;;
    rpi5)
        UBOOT_CONFIG="rpi_arm64_defconfig"
        UBOOT_ARCH="arm64"
        ;;
    orangepi5)
        UBOOT_CONFIG="orangepi-5-rk3588_defconfig"
        UBOOT_ARCH="arm64"
        ;;
    rockpro64)
        UBOOT_CONFIG="rockpro64-rk3399_defconfig"
        UBOOT_ARCH="arm64"
        ;;
    pinebookpro)
        UBOOT_CONFIG="pinebook-pro-rk3399_defconfig"
        UBOOT_ARCH="arm64"
        ;;
    qemu-arm)
        UBOOT_CONFIG="qemu_arm64_defconfig"
        UBOOT_ARCH="arm64"
        ;;
esac

# ============================================================================
# INSTALLATION
# ============================================================================
# Install path for U-Boot
UBOOT_INSTALL_PATH="/boot"

# Device for U-Boot installation (e.g., /dev/mmcblk0)
UBOOT_DEVICE="/dev/mmcblk0"

# Offset for U-Boot on SD card (sectors)
UBOOT_OFFSET="64"

# ============================================================================
# BOOT SCRIPT
# ============================================================================
# Create boot script (boot.scr)
CREATE_BOOT_SCRIPT="true"

# Boot script content
BOOT_SCRIPT="
setenv bootargs console=tty1 console=ttyAMA0,115200 root=/dev/mmcblk0p2 rw rootwait
load mmc 0:1 ${kernel_addr_r} /boot/Image
load mmc 0:1 ${fdt_addr_r} /boot/dtbs/rockchip/rk3588-orangepi-5.dtb
booti ${kernel_addr_r} - ${fdt_addr_r}
"