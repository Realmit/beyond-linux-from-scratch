# ============================================================================
# LINUX-LIBRE KERNEL CONFIGURATION FOR GNU FREE SYSTEM
# Kernel without proprietary blobs (FSF compliant)
# ============================================================================

# ============================================================================
# GENERAL SETUP
# ============================================================================
CONFIG_LOCALVERSION="-gnu-libre"
CONFIG_SYSTEM_TRUSTED_KEYS=""
CONFIG_SYSTEM_REVOCATION_KEYS=""
CONFIG_DEFAULT_HOSTNAME="gnu-free"
CONFIG_INIT_ENV_ARG_LIMIT=32

# ============================================================================
# DISABLE PROPRIETARY FEATURES
# ============================================================================
# CONFIG_BINARY_PRINTF is not set
# CONFIG_DRM_LOAD_EDID_FIRMWARE is not set
# CONFIG_FIRMWARE_LOADER is not set
# CONFIG_EXTRA_FIRMWARE is not set

# ============================================================================
# CPU AND MEMORY
# ============================================================================
CONFIG_SMP=y
CONFIG_NR_CPUS=64
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# ============================================================================
# FILE SYSTEMS
# ============================================================================
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_XFS_FS=y
CONFIG_BTRFS_FS=y
CONFIG_FUSE_FS=y
CONFIG_VFAT_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y

# ============================================================================
# NETWORKING (libre)
# ============================================================================
CONFIG_NETFILTER=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_BRIDGE=y
CONFIG_VLAN_8021Q=y
CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y

# ============================================================================
# DRIVERS (libres uniquement)
# ============================================================================
# Intel WiFi (libre)
CONFIG_IWLWIFI=y
CONFIG_IWLWIFI_LEDS=y

# Atheros WiFi (libre)
CONFIG_ATH9K=y
CONFIG_ATH9K_HTC=y

# Ethernet (libre)
CONFIG_E1000E=y
CONFIG_R8169=y

# Audio (libre)
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_USB_AUDIO=y

# ============================================================================
# SECURITY
# ============================================================================
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_CRYPTO=y

# ============================================================================
# VIRTUALIZATION (libre)
# ============================================================================
CONFIG_KVM=y
CONFIG_VHOST_NET=y
CONFIG_VIRTIO_PCI=y

# ============================================================================
# DEBUG (désactivé pour production)
# ============================================================================
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set