  "build_order": [
    {
      "stage": "lfs_core",
      "parallel": false,
      "description": "LFS core system (toolchain, kernel, libc)"
    },
    {
      "stage": "init_systems",
      "parallel": false,
      "description": "Init system (one of: sysvinit/systemd/openrc/runit/s6)"
    },
    {
      "stage": "blfs_core",
      "parallel": true,
      "description": "BLFS core libraries (X11, GTK, DBus, OpenSSL)"
    },
    {
      "stage": "display_managers",
      "parallel": false,
      "description": "Display manager (lightdm/gdm/sddm)"
    },
    {
      "stage": "desktop",
      "parallel": true,
      "description": "Desktop environment (XFCE/GNOME/KDE)"
    },
    {
      "stage": "audio_production",
      "parallel": true,
      "description": "Audio production tools (optional)"
    },
    {
      "stage": "applications",
      "parallel": true,
      "description": "Desktop applications (browsers, office, multimedia)"
    },
    {
      "stage": "java_dev",
      "parallel": true,
      "description": "Java development environment (optional)"
    },
    {
      "stage": "security_tools",
      "parallel": true,
      "description": "Security hardening (optional)"
    },
    {
      "stage": "virtualization",
      "parallel": true,
      "description": "Virtualization/containers (optional)"
    }
  ],

