# ============================================================================
# LINUX KERNEL CONFIGURATION (x86_64)
# Based on LFS 13.0 kernel 6.12.20
# ============================================================================

# ============================================================================
# GENERAL SETUP
# ============================================================================
CONFIG_SYSTEM_TRUSTED_KEYS=""
CONFIG_SYSTEM_REVOCATION_KEYS=""
CONFIG_DEFAULT_HOSTNAME="lfs-desktop"
CONFIG_LOCALVERSION="-lfs"

# ============================================================================
# PROCESSOR TYPE AND FEATURES (x86_64)
# ============================================================================
CONFIG_SMP=y
CONFIG_NR_CPUS=64
CONFIG_PREEMPT_VOLUNTARY=y
# CONFIG_PREEMPT_RT=y  (uncomment for real-time audio)

# ============================================================================
# DEVICE DRIVERS
# ============================================================================
# Audio drivers
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_PCI=y

# Network drivers
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_R8169=y
CONFIG_ATH9K=y
CONFIG_IWLWIFI=y

# Storage drivers
CONFIG_BLK_DEV_NVME=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y

# Input drivers
CONFIG_KEYBOARD_ATKBD=y
CONFIG_MOUSE_PS2=y
CONFIG_HID=y
CONFIG_USB_HID=y

# ============================================================================
# FILE SYSTEMS
# ============================================================================
CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_BTRFS_FS=y
CONFIG_FUSE_FS=y
CONFIG_VFAT_FS=y
CONFIG_NTFS_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# ============================================================================
# NETWORKING
# ============================================================================
CONFIG_NETFILTER=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_BRIDGE=y
CONFIG_VLAN_8021Q=y

# ============================================================================
# SECURITY
# ============================================================================
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_CRYPTO=y

# ============================================================================
# VIRTUALIZATION
# ============================================================================
CONFIG_KVM=y
CONFIG_VHOST_NET=y
CONFIG_VIRTIO_PCI=y