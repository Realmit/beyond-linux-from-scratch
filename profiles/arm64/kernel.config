# Kernel config overrides for ARM64
CONFIG_ARM64_64K_PAGES=y
CONFIG_ARM64_SW_TTBR0_PAN=y
CONFIG_ARM64_BTI=y
CONFIG_ARM64_E0PD=y

# Raspberry Pi specific
CONFIG_ARCH_BCM2835=y
CONFIG_BCM2835_WDT=y
CONFIG_BCM2711=y
CONFIG_BCM2712=y

# CPU governors for ARM
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y

# Graphics for ARM
CONFIG_DRM_VC4=y
CONFIG_FB_SIMPLE=y