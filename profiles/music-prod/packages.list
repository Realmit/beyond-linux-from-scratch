cdda2wav                 # CDDA extraction tool
abcde                    # CLI CD ripper and encoder
whipper                  # Accurate CD ripper
morituri                 # Another accurate CD ripper
cuetools                 # CUE sheet utilities
shntool                  # WAVE/audio file splitter

# ============================================================================
