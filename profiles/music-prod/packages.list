ffmpeg                   # Audio conversion and processing
avconv                   # Libav tools (alternative)
mp3gain                  # MP3 volume normalization
vorbisgain               # Ogg Vorbis volume normalization
normalize-audio          # Audio file normalization
replaygain-tools

# ============================================================================
