# ============================================================================
# LINUX PHONE PROFILE - PinePhone, Librem 5, Brax3
# Téléphonie native sous Linux (appels, SMS, données mobiles)
# ============================================================================

# ============================================================================
# BASE SYSTEM (ARM64)
# ============================================================================
include:../minimal/packages.list

# ============================================================================
# TELEPHONY STACK - ModemManager (recommandé)
# ============================================================================

# ModemManager - Gestion du modem Quectel EG25-G
# https://www.freedesktop.org/wiki/Software/ModemManager/
https://gitlab.freedesktop.org/mobile-broadband/ModemManager/-/archive/1.22.0/ModemManager-1.22.0.tar.xz

# libmbim - MBIM protocol support
https://www.freedesktop.org/software/libmbim/libmbim-1.28.0.tar.xz

# libqmi - QMI protocol support (Quectel EG25-G)
https://www.freedesktop.org/software/libqmi/libqmi-1.34.0.tar.xz

# ============================================================================
# ALTERNATIVE: oFono (stack téléphonie plus légère)
# ============================================================================

# oFono - Open Source Telephony
# Utilisé par certaines distributions pour la flexibilité
https://www.kernel.org/pub/linux/network/ofono/ofono-2.12.tar.xz

# oFono-phonesim - Simulateur de modem (pour test)
https://www.kernel.org/pub/linux/network/ofono/phonesim-1.21.tar.gz

# ============================================================================
# AUDIO POUR APPELS (I2S entre CPU et modem)
# ============================================================================

# ALSA avec support I2S
alsa-lib-1.2.13
alsa-utils-1.2.13

# PipeWire (audio unifié)
pipewire-1.4.0
wireplumber-0.5.6

# Call Audio Manager (gère routage audio pendant les appels)
# https://gitlab.com/megi/audio-call-manager
git://git.code.sf.net/p/audio-call-manager/code

# ============================================================================
# GESTION DE L'ALIMENTATION DU MODEM
# ============================================================================

# eg25-manager - Gestion spécifique pour Quectel EG25-G
# https://source.puri.sm/Librem5/eg25-manager
https://source.puri.sm/Librem5/eg25-manager/-/archive/v0.4.0/eg25-manager-v0.4.0.tar.gz

# Modem power management kernel module (driver spécifique)
# Inclus dans les kernels mainline récents

